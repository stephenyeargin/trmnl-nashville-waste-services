<div class="layout layout--col">
  <div class="">
    <div class="my--5 lg:my--10 text--center">
      <h1 class="title title--large lg:title--xxlarge">
        {% if days_until_pickup == 0 %}
          Bin pickup is today.
        {% else %}
          Next bin pickup is in {{ days_until_pickup }} day{% if days_until_pickup != 1 %}s{% endif %}
        {% endif %}
      </h1>
      <div>
        <span class="description description--base lg:description--xlarge">Place bins at the street no later than 6 a.m.</span>
      </div>
    </div>
    {% render "pickup_events" sorted_events: sorted_events, next_pickup_day: next_pickup_day, icon_size: "large" %}
    {{ layout_name }}
  </div>
  {{ holiday_events }}
</div>

<div class="title_bar">
  <img class="image-stroke image-stroke--large" src="data:image/svg+xml;base64,{{ svg_logo | base64_encode }}" width="24" height="24" alt="" />
  <span class="title">{{ trmnl.plugin_settings.instance_name | default: 'Nashville Waste Services' }}</span>
  <span class="instance">{{ next_pickup_day | date: "%A, %B %-d" }}</span>
</div>
